{
  "google_drive": {
    "folder_id": "replace-with-drive-folder-id",
    "service_account_file": "secrets/google-service-account.json",
    "include_shared_drives": true,
    "recursive": true,
    "preserve_drive_paths": true,
    "allowed_mime_types": [
      "application/pdf",
      "image/svg+xml",
      "application/acad",
      "application/autocad",
      "application/dwg",
      "application/x-dwg",
      "image/vnd.dwg"
    ],
    "allowed_extensions": [
      ".pdf",
      ".svg",
      ".dwg",
      ".dxf"
    ],
    "excluded_folder_name_contains": [
      "Archive"
    ],
    "excluded_folder_names": [
      "OLD"
    ]
  },
  "building": {
    "name": "replace-with-building-name",
    "address": "replace-with-current-address",
    "floors": [1, 2, 3, 4, 5, 6]
  },
  "storage": {
    "raw_dir": "data/raw",
    "parsed_dir": "data/parsed",
    "metadata_dir": "data/metadata",
    "converted_dir": "data/converted"
  },
  "dwg_conversion": {
    "oda_executable": "C:/Program Files/ODA/ODAFileConverter 27.1.0/ODAFileConverter.exe",
    "output_version": "ACAD2018",
    "output_type": "DXF",
    "recurse": true,
    "audit": true,
    "priority_drive_path_prefixes": [
      "04_설계도서/01_건축_구조/",
      "04_설계도서/02_전기/",
      "04_설계도서/03_기계/",
      "04_설계도서/04_통신/"
    ]
  }
}
